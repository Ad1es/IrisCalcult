<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IrisCraftCalc.MainPage"
             Title="Iris Online - Crafting Calculator"
             BackgroundColor="#1E1E1E">
    <Grid>

        <Grid RowDefinitions="60, *" ColumnDefinitions="300, *">

            <Border Grid.Row="0" Grid.ColumnSpan="2" BackgroundColor="#2C3E50" StrokeThickness="0" Padding="15,0">
                <HorizontalStackLayout VerticalOptions="Center" Spacing="20">
                    <Label Text="IrisCraft" FontSize="24" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                    <BoxView WidthRequest="2" Color="#34495E" Margin="0,10"/>

                    <Label Text="👤 Аккаунт: tester | Персонаж: не выбран" TextColor="LightGray" VerticalOptions="Center" x:Name="CharStatusLabel"/>
                    <Button Text="🔄 Синхронизировать" HeightRequest="35" Padding="10,0" BackgroundColor="#27AE60" TextColor="White"/>
                </HorizontalStackLayout>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" BackgroundColor="White" StrokeThickness="0" Padding="10">
                <VerticalStackLayout Spacing="10">

                    <Label Text="Выберите ремесло:" FontSize="14" TextColor="Black"/>
                    <Picker x:Name="ProfessionPicker" Title="Ремесло" TitleColor="Black" BackgroundColor="White" SelectedIndex="2" TextColor="Black">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>Снедь (Кулинар)</x:String>
                                <x:String>Зелья (Алхимик)</x:String>
                                <x:String>Ремесленник (Оружие/Броня)</x:String>
                                <x:String>Карты Таро (Картежник)</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>

                    <SearchBar Placeholder="Поиск предмета..." BackgroundColor="White" TextColor="Black" CancelButtonColor="Gray"/>

                    <CollectionView x:Name="RecipesList" SelectionMode="Single">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="10" ColumnDefinitions="Auto, *">
                                    <BoxView WidthRequest="32" HeightRequest="32" Color="LightGray" Margin="0,0,10,0"/>
                                    <Label Grid.Column="1" Text="{Binding Name}" VerticalOptions="Center" TextColor="Black"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Grid Grid.Row="1" Grid.Column="1" RowDefinitions="Auto, *" Padding="20">
                <HorizontalStackLayout Grid.Row="0" Spacing="20" Margin="0,0,0,20">
                    <BoxView WidthRequest="64" HeightRequest="64" Color="LightGray"/>
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label Text="Стальной доспех" FontSize="28" FontAttributes="Bold" TextColor="White"/>
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="Количество:" VerticalOptions="Center" TextColor="LightGray"/>
                            <Entry Text="1" Keyboard="Numeric" WidthRequest="60" HorizontalTextAlignment="Center" TextColor="White" BackgroundColor="#333"/>
                            <Stepper Minimum="1" Maximum="100" Increment="1" BackgroundColor="White"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <Border Grid.Row="1" BackgroundColor="#2D2D30" Stroke="#444" StrokeThickness="1" Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Необходимые ресурсы:" FontSize="18" FontAttributes="Bold" TextColor="White"/>

                        <Grid ColumnDefinitions="*, 100, 100, 100" Padding="5" BackgroundColor="#3E3E42">
                            <Label Grid.Column="0" Text="Материал" FontAttributes="Bold" TextColor="White"/>
                            <Label Grid.Column="1" Text="Нужно" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="White"/>
                            <Label Grid.Column="2" Text="В инвентаре" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="White"/>
                            <Label Grid.Column="3" Text="Осталось" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="White"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Grid>


        <ContentView x:Name="LoginOverlay" BackgroundColor="#D9000000" IsVisible="True">
            <Border WidthRequest="350" HeightRequest="400" BackgroundColor="#1E1E1E" Stroke="#3498DB" StrokeThickness="2" VerticalOptions="Center" HorizontalOptions="Center" Padding="30">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="20" VerticalOptions="Center">
                    <Label Text="Вход в систему" FontSize="24" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                    <Label Text="Введите данные от аккаунта Iris Online для привязки инвентаря" FontSize="12" TextColor="Gray" HorizontalTextAlignment="Center"/>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Логин:" TextColor="LightGray"/>
                        <Entry x:Name="LoginEntry" Placeholder="Имя пользователя" TextColor="White" BackgroundColor="#333" PlaceholderColor="Gray"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Пароль:" TextColor="LightGray"/>
                        <Entry x:Name="PasswordEntry" Placeholder="Пароль от игры" IsPassword="True" TextColor="White" BackgroundColor="#333" PlaceholderColor="Gray"/>
                    </VerticalStackLayout>

                    <Button Text="Войти и привязать аккаунт" BackgroundColor="#3498DB" TextColor="White" FontAttributes="Bold" CornerRadius="5" HeightRequest="45" Margin="0,15,0,0" x:Name="LoginBtn" Clicked="LoginBtn_Clicked"/>
                </VerticalStackLayout>
            </Border>
        </ContentView>

    </Grid>
</ContentPage>